{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "View Bomber",
  "version": "0.1.0",
  "identifier": "com.takahirosuzuki.view-bomber",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run prepare:pdf-tools && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "View Bomber",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../LICENSE",
      "../THIRD_PARTY_NOTICES.md",
      "../APACHE_NOTICES.md",
      "../resources/bin"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
