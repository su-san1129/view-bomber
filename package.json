{
  "name": "view-bomber",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "viewb": "scripts/viewb.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "viewb": "bun scripts/viewb.mjs",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "check": "bun run format:check && bun run lint && bunx tsc --noEmit && cd src-tauri && cargo check",
    "lint": "bun run lint:frontend && bun run lint:rust",
    "lint:frontend": "oxlint src vite.config.ts --deny-warnings",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "licenses:generate": "bun scripts/generate-third-party-licenses.mjs",
    "licenses:check": "bun run licenses:generate --strict && git diff --exit-code -- LICENSE THIRD_PARTY_NOTICES.md APACHE_NOTICES.md",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md}": [
      "dprint fmt"
    ],
    "src/**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --deny-warnings"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "allotment": "^1.20.5",
    "dxf-parser": "^1.1.2",
    "highlight.js": "^11.11.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.12.3",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "dprint": "^0.52.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.16.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
